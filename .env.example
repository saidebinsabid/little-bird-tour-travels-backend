# ── Server ────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# Comma-separated list of allowed frontend origins (CORS).
# Production example: https://yourapp.com,https://www.yourapp.com
CORS_ORIGINS=http://localhost:3000

# Public URL of the frontend (used to build links in emails, etc.)
APP_URL=http://localhost:3000

# Production only: shared parent domain so the Next.js app can read the
# session cookie set by the API subdomain. Example: .yourapp.com
# COOKIE_DOMAIN=.yourapp.com

# ── MongoDB ───────────────────────────────────────────────
# Either a full connection string, or user/pass that config/db.js composes.
MONGODB_URI=mongodb://localhost:27017
DB_NAME=appdb
# DB_USER=your_db_user
# DB_PASS=your_db_password

# ── Auth ──────────────────────────────────────────────────
# Long random string (32+ chars). Generate with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace_with_a_long_random_secret

# ── Seed admin (used by `node seed/seed.js`) ──────────────
SEED_ADMIN_EMAIL=admin@littlebirdtours.com
SEED_ADMIN_PASSWORD=Admin@123

# ── Media uploads (Cloudinary) ────────────────────────────
# Cloud name is public (also baked into lib/cloudinary.js as a default).
# Only the API key + secret are sensitive — set them to enable image uploads.
CLOUDINARY_CLOUD_NAME=dfgz1ss49
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=

# ── Firebase (verifies Google sign-in tokens; project id is public) ──
FIREBASE_PROJECT_ID=little-bird-tour-travels

# ── Email / SMS notifications (lead + booking alerts) ─────
# EMAIL_USER=
# EMAIL_PASS=
# SMS_API_KEY=
# SMS_SENDER_ID=

# ── Payment gateways (Phase 2 — model already in place) ───
# BKASH_APP_KEY=
# BKASH_APP_SECRET=
# NAGAD_MERCHANT_ID=
# SSLCZ_STORE_ID=
# SSLCZ_STORE_PASSWORD=
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
